{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"strict": true,
		"allowJs": true,
		"checkJs": false,
		"skipLibCheck": true,
		"isolatedModules": true,
		"noEmitOnError": false,
		"noEmit": true,
		"types": ["vite/client"]
	},
	"include": ["src"]
}
